---
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  twitterCard?: "summary" | "summary_large_image";
  noindex?: boolean;
  nofollow?: boolean;
  keywords?: string[];
  breadcrumbItems?: Array<{
    name: string;
    url: string;
  }>;
  jsonLd?: JsonLdNode | JsonLdNode[];
}

type JsonLdNode = Record<string, unknown>;

const {
  title,
  description,
  canonical,
  ogType = "website",
  ogImage = "/og-image.svg",
  ogImageAlt = "Zen Typer mindful typing test and practice interface",
  twitterCard = "summary_large_image",
  noindex = false,
  nofollow = false,
  keywords = [
    "typing test",
    "typing trainer",
    "typing practice",
    "mindful typing",
    "typing speed test",
    "WPM test",
  ],
  breadcrumbItems = [],
  jsonLd,
} = Astro.props;

const siteOrigin = new URL(Astro.site?.href || Astro.url.origin).origin;
const siteRoot = new URL("/", siteOrigin).href;
const currentUrl = canonical || new URL(Astro.url.pathname, siteOrigin).href;
const fullOgImage = new URL(ogImage, siteOrigin).href;
const keywordsContent = keywords.join(", ");

const robotsContent = [
  noindex ? "noindex" : "index",
  nofollow ? "nofollow" : "follow",
].join(", ");

const creatorJsonLd: JsonLdNode = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": new URL("#creator", siteRoot).href,
  name: "Jonathan Reed",
  alternateName: "Jonathan R Reed",
  url: "https://jonathanrreed.com",
};

const websiteJsonLd: JsonLdNode = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": new URL("#website", siteRoot).href,
  name: "Zen Typer",
  url: siteRoot,
  inLanguage: "en-US",
  description:
    "A free mindful typing test and practice app for focus, WPM, accuracy, Zen quotes, and free-flow writing.",
  publisher: {
    "@id": new URL("#creator", siteRoot).href,
  },
};

const breadcrumbJsonLd: JsonLdNode | null =
  breadcrumbItems.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "@id": `${currentUrl}#breadcrumb`,
        itemListElement: breadcrumbItems.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: item.url,
        })),
      }
    : null;

const pageJsonLd: JsonLdNode = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${currentUrl}#webpage`,
  name: title,
  headline: title,
  description,
  url: currentUrl,
  datePublished: "2026-04-21",
  dateModified: "2026-04-21",
  inLanguage: "en-US",
  isPartOf: {
    "@id": new URL("#website", siteRoot).href,
  },
  author: {
    "@id": new URL("#creator", siteRoot).href,
  },
  publisher: {
    "@id": new URL("#creator", siteRoot).href,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: fullOgImage,
    width: 1200,
    height: 630,
  },
  ...(breadcrumbJsonLd
    ? {
        breadcrumb: {
          "@id": `${currentUrl}#breadcrumb`,
        },
      }
    : {}),
};

const customJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const structuredData = [
  creatorJsonLd,
  websiteJsonLd,
  pageJsonLd,
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
  ...customJsonLd,
];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="application-name" content="Zen Typer" />
<meta name="apple-mobile-web-app-title" content="Zen Typer" />
<meta name="author" content="Jonathan Reed" />

<!--
  Pre-paint theme bootstrap.
  Runs synchronously before the browser renders anything so the correct
  theme class is present on <html> from the very first frame. Prevents the
  Void-default → chosen-theme "pop-in" on initial load and after a
  ClientRouter navigation.
-->
<script is:inline>
  (function () {
    try {
      var themeClasses = ["theme-void", "theme-forest", "theme-ocean", "theme-cosmic"];
      var root = document.documentElement;

      var raw = null;
      try {
        raw = localStorage.getItem("zt.settings");
      } catch (storageErr) {
        raw = null;
        void storageErr;
      }

      var parsed = null;
      if (raw) {
        try {
          parsed = JSON.parse(raw);
        } catch (parseErr) {
          parsed = null;
          void parseErr;
        }
      }

      var theme = (parsed && parsed.theme) ? String(parsed.theme).toLowerCase() : "void";
      if (themeClasses.indexOf("theme-" + theme) === -1) theme = "void";

      for (var i = 0; i < themeClasses.length; i++) root.classList.remove(themeClasses[i]);
      root.classList.add("theme-" + theme);

      // Motion preference: data-motion="on" | "off"
      var motion = (parsed && parsed.reducedMotion) ? "off" : "on";
      var prefersReduced = false;
      try {
        prefersReduced = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      } catch (mqErr) {
        prefersReduced = false;
        void mqErr;
      }
      if (prefersReduced) motion = "off";
      root.setAttribute("data-motion", motion);

      // High-contrast preference.
      if (parsed && parsed.highContrast) {
        root.classList.add("high-contrast");
      } else {
        root.classList.remove("high-contrast");
      }
    } catch (bootErr) {
      // Fail silently and let ThemeToggle sort it out after hydration.
      void bootErr;
    }
  })();
</script>

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywordsContent} />
<meta name="robots" content={robotsContent} />
<link rel="canonical" href={currentUrl} />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Astro View Transitions: cross-fades between pages, keeps persistent layers mounted -->
<ClientRouter fallback="swap" />

<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={currentUrl} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Zen Typer" />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<meta
  name="theme-color"
  content="#191724"
  media="(prefers-color-scheme: dark)"
/>
<meta
  name="theme-color"
  content="#faf4ed"
  media="(prefers-color-scheme: light)"
/>

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(structuredData)}
/>

<link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
<link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
<link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
<link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png" sizes="180x180" />
<link rel="manifest" href="/site.webmanifest" />
