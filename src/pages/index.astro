---
import "../styles/globals.css";
import QuoteTyper from "../components/QuoteTyper";
import StatsBar from "../components/StatsBar";
import PauseMenu from "../components/PauseMenu";
import HelpSheet from "../components/HelpSheet";
import AboutOverlay from "../components/AboutOverlay";
import ArchiveOverlay from "../components/ArchiveOverlay";
import SiteFooter from "../components/SiteFooter";
import SiteHeader from "../components/SiteHeader";
import ErrorBoundary from "../components/ErrorBoundary";
import SEO from "../components/SEO.astro";
import SpotlightLayer from "../components/SpotlightLayer";
import { loadQuotes, getRandomQuote } from "../utils/quotes";

const quotes = await loadQuotes();
const randomQuote = getRandomQuote(quotes);
const siteUrl = "https://zentype.jonathanrreed.com";
const homeUrl = `${siteUrl}/`;
---

<!doctype html>
<html lang="en">
	<head>
		<SEO
			title="Mindful Typing Test and Practice for Focus"
			description="Zen Typer is a free mindful typing test and practice app for focus, WPM, accuracy, Zen quotes, and free-flow writing in a distraction-free workspace."
			canonical={homeUrl}
			keywords={[
				"typing test",
				"mindful typing test",
				"typing practice",
				"typing trainer",
				"WPM test",
				"typing accuracy",
			]}
			breadcrumbItems={[
				{ name: "Mindful typing test", url: homeUrl },
			]}
		/>
		<!-- Developer Console Easter Egg -->
		<script>
			(function () {
				if (typeof window === "undefined") return;

				const ascii = `
    ___  ________  ________     
   |\\  \\|\\   __  \\|\\   __  \\    
   \\ \\  \\ \\  \\|\\  \\ \\  \\|\\  \\   
 __ \\ \\  \\ \\   _  _\\ \\   _  _\\  
|\\  \\\\_\\  \\ \\  \\\\  \\\\ \\  \\\\  \\|
\\ \\________\\ \\__\\\\ _\\\\ \\__\\\\ _\\
 \\|________|\\|__|\\|__|\\|__|\\|__|
				`;

				console.log(ascii);
				console.log("Hey there. Interested in code?");
				console.log(
					"Check out my GitHub: https://github.com/JonathanRReed",
				);
				console.log("Most of my sites repos are open source.");
			})();
		</script>
	</head>
	<body>
		<ErrorBoundary>
			<a
				href="#quote-app"
				class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-iris focus:text-base focus:rounded-lg focus:shadow-lg"
			>
				Skip to main content
			</a>
			<div
				id="quote-app"
				class="relative w-full min-h-screen overflow-hidden stats-cq-host"
			>
				<h1 class="sr-only">Mindful Typing Test and Practice</h1>
				<p class="sr-only">
					Zen Typer is a free mindful typing test and typing practice
					workspace by Jonathan Reed. Practice with Zen quotes, track
					WPM and accuracy, or move into free-flow typing when you want
					a calmer writing rhythm.
				</p>
				<SiteHeader client:load mode="quote" />
				<div
					class="pointer-events-none fixed inset-0 z-0 theme-layer"
				>
					<div class="forest-rays" aria-hidden="true"></div>
					<div class="ocean-lights" aria-hidden="true">
						<div class="stars-near" aria-hidden="true"></div>
						<div class="stars-far" aria-hidden="true"></div>
					</div>
				</div>
				<SpotlightLayer client:load transition:persist="spotlight" />

				<div
					class="relative z-10 flex w-full items-center justify-center px-6 py-12 pb-40"
				>
					<div class="w-full max-w-4xl">
						<QuoteTyper
							client:load
							quote={randomQuote.text}
							author={randomQuote.author}
							onComplete={(summary) => {
								const completeEvent = new CustomEvent(
									"quoteComplete",
									{ detail: summary },
								);
								window.dispatchEvent(completeEvent);
							}}
						/>
					</div>
				</div>

				<StatsBar
					client:idle
					mode="quote"
					visible={true}
					metrics={{}}
				/>

				<PauseMenu
					client:idle
					mode="quote"
					onReset={() => {
						window.dispatchEvent(new CustomEvent("newQuote"));
					}}
					data-pause-menu
				/>

				<HelpSheet client:idle isOpen={false} onClose={() => {}} />
				<ArchiveOverlay client:idle />
				<AboutOverlay client:idle />
				<SiteFooter client:idle />
			</div>
		</ErrorBoundary>

		<section
			class="mx-auto max-w-5xl px-6 pb-28 pt-16 text-muted"
			aria-labelledby="home-seo-heading"
		>
			<div
				class="grid gap-10 border-t border-iris/15 pt-10 md:grid-cols-[1.15fr_0.85fr]"
			>
				<div class="space-y-4">
					<p class="text-sm font-medium text-foam">Typing practice</p>
					<h2
						id="home-seo-heading"
						class="max-w-2xl text-3xl font-semibold text-text md:text-4xl"
					>
						A mindful typing test for focus, speed, and accuracy.
					</h2>
					<p class="max-w-2xl text-base leading-7 text-muted md:text-lg">
						Zen Typer combines a free typing test with quiet practice
						sessions, real-time WPM, accuracy feedback, and a
						free-flow writing mode for people who want typing practice
						without a noisy game layer.
					</p>
				</div>
				<div class="space-y-5 text-sm leading-6">
					<div>
						<h3 class="font-semibold text-text">Practice options</h3>
						<p>
							Start with the quote typing test for measured speed and
							accuracy, then switch to Zen Mode when you want a longer
							focused writing session.
						</p>
					</div>
					<div class="flex flex-wrap gap-4">
						<a class="text-foam transition-colors hover:text-text" href="/quote">
							Quote typing test
						</a>
						<a class="text-foam transition-colors hover:text-text" href="/zen">
							Free-flow typing practice
						</a>
					</div>
				</div>
			</div>
		</section>

		<script>
			import { navigate } from "astro:transitions/client";

			let isPaused = false;

			/** @param {KeyboardEvent} e */
			const handleKeys = (e) => {
				const ae = document.activeElement;
				const tag = ae && ae.tagName ? ae.tagName.toLowerCase() : "";
				const isTyping = tag === "input" || tag === "textarea";

				if (
					!isTyping &&
					e.key === "Tab" &&
					!e.ctrlKey &&
					!e.metaKey &&
					!e.shiftKey
				) {
					e.preventDefault();
					navigate("/zen");
				}

				if (e.key === "Escape") {
					e.preventDefault();
					isPaused = !isPaused;
					window.dispatchEvent(
						new CustomEvent("togglePause", { detail: isPaused }),
					);
				}
			};

			// Attach once; ClientRouter preserves listeners via persist markers.
			document.addEventListener("keydown", handleKeys);
			document.addEventListener("astro:before-swap", () => {
				document.removeEventListener("keydown", handleKeys);
			});
			document.addEventListener("astro:after-swap", () => {
				document.addEventListener("keydown", handleKeys);
			});
		</script>
	</body>
</html>
