---
import "../styles/globals.css";
import QuoteTyper from "../components/QuoteTyper";
import StatsBar from "../components/StatsBar";
import PauseMenu from "../components/PauseMenu";
import HelpSheet from "../components/HelpSheet";
import AboutOverlay from "../components/AboutOverlay";
import ArchiveOverlay from "../components/ArchiveOverlay";
import SiteFooter from "../components/SiteFooter";
import SiteHeader from "../components/SiteHeader";
import ErrorBoundary from "../components/ErrorBoundary";
import SEO from "../components/SEO.astro";
import SpotlightLayer from "../components/SpotlightLayer";
import { loadQuotes, getRandomQuote } from "../utils/quotes";

// Load a random quote at build time
const quotes = await loadQuotes();
const randomQuote = getRandomQuote(quotes);
const siteUrl = "https://zentype.jonathanrreed.com";
const homeUrl = `${siteUrl}/`;
const quoteUrl = `${siteUrl}/quote/`;
---

<!doctype html>
<html lang="en">
	<head>
		<SEO
			title="Zen Quote Typing Test for Speed and Accuracy"
			description="Take a mindful typing test with curated Zen quotes, real-time WPM, accuracy tracking, and clean practice sessions built for focus and rhythm."
			canonical={quoteUrl}
			keywords={[
				"typing test",
				"typing speed test",
				"WPM test",
				"typing accuracy",
				"Zen quotes",
				"typing practice",
			]}
			breadcrumbItems={[
				{ name: "Mindful typing test", url: homeUrl },
				{ name: "Zen quote typing test", url: quoteUrl },
			]}
		/>
	</head>
	<body>
		<ErrorBoundary>
			<a
				href="#quote-app"
				class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-iris focus:text-base focus:rounded-lg focus:shadow-lg"
			>
				Skip to main content
			</a>
			<main
				id="quote-app"
				class="relative w-full min-h-screen overflow-hidden stats-cq-host"
			>
				<h1 class="sr-only">
					Zen Quote Typing Test for Speed and Accuracy
				</h1>
				<SiteHeader client:load mode="quote" />
				<div
					class="pointer-events-none fixed inset-0 z-0 theme-layer"
				>
					<div class="forest-rays" aria-hidden="true"></div>
					<div class="ocean-lights" aria-hidden="true">
						<div class="stars-near" aria-hidden="true"></div>
						<div class="stars-far" aria-hidden="true"></div>
					</div>
				</div>
				<SpotlightLayer client:load transition:persist="spotlight" />

				<div
					class="relative z-10 flex w-full items-center justify-center px-6 py-12 pb-40"
				>
					<div class="w-full max-w-4xl">
						<QuoteTyper
							client:load
							quote={randomQuote.text}
							author={randomQuote.author}
							onComplete={(summary) => {
								// Handle completion
								const completeEvent = new CustomEvent(
									"quoteComplete",
									{ detail: summary },
								);
								window.dispatchEvent(completeEvent);
							}}
						/>
					</div>
				</div>

				<StatsBar
					client:idle
					mode="quote"
					visible={true}
					metrics={{}}
				/>

				<PauseMenu
					client:idle
					mode="quote"
					onReset={() => {
						// Smoothly load a new quote without reload
						window.dispatchEvent(new CustomEvent("newQuote"));
					}}
					data-pause-menu
				/>

				<HelpSheet client:idle isOpen={false} onClose={() => {}} />
				<ArchiveOverlay client:idle />
				<AboutOverlay client:idle />
				<SiteFooter client:idle />
			</main>
		</ErrorBoundary>

		<section
			class="mx-auto max-w-5xl px-6 pb-28 pt-16 text-muted"
			aria-labelledby="quote-seo-heading"
		>
			<div
				class="grid gap-10 border-t border-iris/15 pt-10 md:grid-cols-[1.15fr_0.85fr]"
			>
				<div class="space-y-4">
					<p class="text-sm font-medium text-foam">Quote mode</p>
					<h2
						id="quote-seo-heading"
						class="max-w-2xl text-3xl font-semibold text-text md:text-4xl"
					>
						A Zen quote typing test with WPM and accuracy.
					</h2>
					<p class="max-w-2xl text-base leading-7 text-muted md:text-lg">
						Quote Mode gives each typing test a short passage, live
						accuracy feedback, and WPM tracking. It is built for clean
						repetition, focused practice, and steady speed gains.
					</p>
				</div>
				<div class="space-y-5 text-sm leading-6">
					<div>
						<h3 class="font-semibold text-text">Best for</h3>
						<p>
							Use this mode when you want a fast typing speed test with
							curated Zen quotes, precise feedback, and a calmer pace
							than competitive typing games.
						</p>
					</div>
					<div>
						<h3 class="font-semibold text-text">What it measures</h3>
						<p>
							Quote Mode tracks speed, accuracy, completion, slips, skips,
							and extra characters while keeping the page visually quiet.
							That makes it easier to repeat a short passage, notice where
							your hands rush, and reset for another round without opening
							a crowded dashboard.
						</p>
					</div>
					<div class="flex flex-wrap gap-4">
						<a class="text-foam transition-colors hover:text-text" href="/">
							Mindful typing practice
						</a>
						<a class="text-foam transition-colors hover:text-text" href="/zen/">
							Free-flow typing practice
						</a>
					</div>
				</div>
				<div class="md:col-span-2 grid gap-6 border-t border-iris/15 pt-8 text-sm leading-6 md:grid-cols-3">
					<div>
						<h3 class="font-semibold text-text">Repeatable drills</h3>
						<p>
							Short quotes create a repeatable loop for warming up before
							writing, checking keyboard accuracy, or easing back into
							focused work after a context switch.
						</p>
					</div>
					<div>
						<h3 class="font-semibold text-text">Local flow</h3>
						<p>
							The app can remember settings in your browser and does not
							require a profile. You can adjust the theme, motion, and
							feedback without changing the purpose of the page.
						</p>
					</div>
					<div>
						<h3 class="font-semibold text-text">Trust links</h3>
						<p>
							Learn who maintains the app on <a class="text-foam transition-colors hover:text-text" href="/about/">about</a>,
							report an issue through <a class="text-foam transition-colors hover:text-text" href="/contact/">contact</a>,
							or check how browser storage is used in the <a class="text-foam transition-colors hover:text-text" href="/privacy/">privacy notice</a>.
						</p>
					</div>
				</div>
			</div>
		</section>

		<script>
			let isPaused = false;
			document.addEventListener("keydown", (e) => {
				const ae = document.activeElement;
				const tag = ae && ae.tagName ? ae.tagName.toLowerCase() : "";
				const isTyping = tag === "input" || tag === "textarea";
				// Tab to switch to Zen mode
				if (
					!isTyping &&
					e.key === "Tab" &&
					!e.ctrlKey &&
					!e.metaKey &&
					!e.shiftKey
				) {
					e.preventDefault();
					window.location.assign("/zen/");
				}

				// Esc for pause menu
				if (e.key === "Escape") {
					e.preventDefault();
					isPaused = !isPaused;
					const pauseEvent = new CustomEvent("togglePause", {
						detail: isPaused,
					});
					window.dispatchEvent(pauseEvent);
				}
			});

			// Quote completion is handled within QuoteTyper (stats persisted + event dispatched)
		</script>
	</body>
</html>
