---
import "../styles/globals.css";
import ZenCanvas from "../components/ZenCanvas";
import StatsBar from "../components/StatsBar";
import PauseMenu from "../components/PauseMenu";
import HelpSheet from "../components/HelpSheet";
import ArchiveOverlay from "../components/ArchiveOverlay";
import AboutOverlay from "../components/AboutOverlay";
import SiteFooter from "../components/SiteFooter";
import SiteHeader from "../components/SiteHeader";
import ErrorBoundary from "../components/ErrorBoundary";
import SEO from "../components/SEO.astro";
import SpotlightLayer from "../components/SpotlightLayer";

const siteUrl = "https://zentype.jonathanrreed.com";
const homeUrl = `${siteUrl}/`;
const zenUrl = `${siteUrl}/zen`;
---

<!doctype html>
<html lang="en">
	<head>
		<SEO
			title="Free-Flow Typing Practice for Focused Writing"
			description="Use Zen Mode for free-flow typing practice that keeps words moving, tracks local session stats, and gives focused writers a calm space to build rhythm."
			canonical={zenUrl}
			keywords={[
				"typing practice",
				"free-flow typing",
				"mindful typing",
				"typing trainer",
				"focused writing",
				"writing practice",
			]}
			breadcrumbItems={[
				{ name: "Mindful typing test", url: homeUrl },
				{ name: "Free-flow typing practice", url: zenUrl },
			]}
		/>
		<!-- Developer Console Easter Egg -->
		<script>
			(function () {
				if (typeof window === "undefined") return;

				const ascii = `
    ___  ________  ________     
   |\\  \\|\\   __  \\|\\   __  \\    
   \\ \\  \\ \\  \\|\\  \\ \\  \\|\\  \\   
 __ \\ \\  \\ \\   _  _\\ \\   _  _\\  
|\\  \\\\_\\  \\ \\  \\\\  \\\\ \\  \\\\  \\|
\\ \\________\\ \\__\\\\ _\\\\ \\__\\\\ _\\
 \\|________|\\|__|\\|__|\\|__|\\|__|
				`;

				console.log(ascii);
				console.log("Hey there. Interested in code?");
				console.log(
					"Check out my GitHub: https://github.com/JonathanRReed",
				);
				console.log("Most of my sites repos are open source.");
			})();
		</script>
	</head>
	<body>
		<ErrorBoundary>
			<!-- Skip to main content link for accessibility -->
			<a
				href="#zen-app"
				class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-iris focus:text-base focus:rounded-lg focus:shadow-lg"
			>
				Skip to main content
			</a>
			<div
				id="zen-app"
				class="relative w-full min-h-screen overflow-hidden stats-cq-host"
			>
				<h1 class="sr-only">
					Free-Flow Typing Practice for Focused Writing
				</h1>
				<SiteHeader client:load mode="zen" />

				<!-- Main canvas -->
				<!-- Theme background layers (behind tokens) -->
				<div
					class="pointer-events-none fixed inset-0 z-0 theme-layer"
				>
					<div class="forest-rays" aria-hidden="true"></div>
					<div class="ocean-lights" aria-hidden="true">
						<div class="stars-near" aria-hidden="true"></div>
						<div class="stars-far" aria-hidden="true"></div>
					</div>
				</div>
				<SpotlightLayer client:load transition:persist="spotlight" />

				<ZenCanvas
					client:load
					fontFamily="JetBrains Mono"
					maxTokens={160}
				/>

				<!-- Stats bar -->
				<StatsBar client:idle mode="zen" visible={true} metrics={{}} />

				<!-- Pause menu -->
				<PauseMenu
					client:idle
					mode="zen"
					onReset={() => {
						window.location.reload();
					}}
					data-pause-menu
				/>

				<!-- Help sheet -->
				<HelpSheet client:idle isOpen={false} onClose={() => {}} />

				<!-- Archive & About overlays (hidden by default) -->
				<ArchiveOverlay client:idle />
				<AboutOverlay client:idle />
				<SiteFooter client:idle />
			</div>
		</ErrorBoundary>

		<section
			class="mx-auto max-w-5xl px-6 pb-28 pt-16 text-muted"
			aria-labelledby="zen-seo-heading"
		>
			<div
				class="grid gap-10 border-t border-iris/15 pt-10 md:grid-cols-[1.15fr_0.85fr]"
			>
				<div class="space-y-4">
					<p class="text-sm font-medium text-foam">Free-flow mode</p>
					<h2
						id="zen-seo-heading"
						class="max-w-2xl text-3xl font-semibold text-text md:text-4xl"
					>
						Typing practice for focused writing sessions.
					</h2>
					<p class="max-w-2xl text-base leading-7 text-muted md:text-lg">
						Zen Mode turns typing practice into an open writing flow.
						Words move through the canvas while local stats track
						rhythm, pace, and session progress without breaking focus.
					</p>
				</div>
				<div class="space-y-5 text-sm leading-6">
					<div>
						<h3 class="font-semibold text-text">Best for</h3>
						<p>
							Use this mode for warmups, mindful typing practice,
							drafting, and longer sessions where steady rhythm matters
							more than racing a timer.
						</p>
					</div>
					<div class="flex flex-wrap gap-4">
						<a class="text-foam transition-colors hover:text-text" href="/">
							Mindful typing test
						</a>
						<a class="text-foam transition-colors hover:text-text" href="/quote">
							Quote typing test
						</a>
					</div>
				</div>
			</div>
		</section>

		<script>
			let isPaused = false;

			document.addEventListener("keydown", (e) => {
				const el = document.activeElement;
				const tag = el && el.tagName ? el.tagName.toLowerCase() : "";
				const isTyping = tag === "input" || tag === "textarea";
				if (
					!isTyping &&
					e.key === "Tab" &&
					!e.ctrlKey &&
					!e.metaKey &&
					!e.shiftKey
				) {
					e.preventDefault();
					window.location.assign("/quote");
				}
				if (e.key === "Escape") {
					e.preventDefault();
					isPaused = !isPaused;
					window.dispatchEvent(
						new CustomEvent("togglePause", { detail: isPaused }),
					);
				}
			});

			// Handle pause menu state changes
			window.addEventListener("togglePause", function (event) {
				let detail;
				if (
					typeof event === "object" &&
					event !== null &&
					"detail" in event
				) {
					detail = /** @type {CustomEvent<boolean | undefined>} */ (
						event
					).detail;
				}
				isPaused = typeof detail === "boolean" ? detail : !isPaused;
				// Update the pause menu component
				const pauseMenu = document.querySelector("[data-pause-menu]");
				if (pauseMenu) {
					pauseMenu.setAttribute("data-is-open", isPaused.toString());
				}
			});
		</script>
	</body>
</html>
